# Copy this file to `backend/.env` for local development only.
# Never commit the real `.env` file or any personal credentials.
# Replace all placeholder values before startup.

VAT_APP_ENV=development
VAT_DATABASE_URL=postgresql+psycopg://<db-user>:<db-password>@127.0.0.1:5432/AutoTestDev
VAT_DATABASE_ADMIN_URL=postgresql+psycopg://<db-user>:<db-password>@127.0.0.1:5432/postgres
# Local convenience only. Keep disabled outside development.
VAT_DATABASE_AUTO_CREATE=true
VAT_DATABASE_AUTO_MIGRATE=true

# Default admin is seeded only when the user does not already exist.
VAT_DEFAULT_ADMIN_USERNAME=admin
VAT_DEFAULT_ADMIN_PASSWORD=change-me-before-use
VAT_JWT_SECRET_KEY=change-me-jwt-secret
VAT_JWT_ALGORITHM=HS256
VAT_JWT_ISSUER=visionautotest-backend
VAT_DATA_ENCRYPTION_KEY=change-me-data-encryption-key

# Local runtime paths
VAT_LOCAL_STORAGE_PATH=.data/media

# Optional runtime overrides
VAT_DEMO_TARGET_BASE_URL=http://127.0.0.1:8000/demo/acceptance-target
VAT_PLAYWRIGHT_HEADLESS=true
VAT_PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=15000
